class Taevakeha:
    def __init__(self, nimi):
        self.nimi = nimi
        self._vaadeldav = False

    def alusta_vaatlust(self):
        self._vaadeldav = True
        print(f"{self.nimi} on nüüd vaatluse all.")

    def lopeta_vaatlus(self):
        self._vaadeldav = False
        print(f"{self.nimi} ei ole enam vaadeldav.")

    def __str__(self):
        return f"Taevakeha: {self.nimi}"


class Planeet(Taevakeha):
    def __init__(self, nimi, kaugus):
        super().__init__(nimi)
        self.kaugus = kaugus  

    def kuva_andmed(self):
        print(f"{self.nimi} kaugus Päikesest: {self.kaugus} miljonit km")


class KivinePlaneet(Planeet):
    def __init__(self, nimi, kaugus, atmosfaar):
        super().__init__(nimi, kaugus)
        self.atmosfaar = atmosfaar  

    def kontrolli_atmosfaari(self):
        if self._vaadeldav:
            if self.atmosfaar:
                print(f"{self.nimi}l on atmosfäär.")
            else:
                print(f"{self.nimi}l puudub atmosfäär.")
        else:
            print("Planeeti peab enne vaatlema!")


class GaasiPlaneet(Planeet):
    def __init__(self, nimi, kaugus, kuude_arv):
        super().__init__(nimi, kaugus)
        self.kuude_arv = kuude_arv

    def kuva_kuud(self):
        if self._vaadeldav:
            print(f"{self.nimi}l on {self.kuude_arv} kuud.")
        else:
            print("Planeeti peab enne vaatlema!")


